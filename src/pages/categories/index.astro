---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getPublishedPosts, buildTaxonomy, categoryPath } from '~/lib/posts.js';
import { t } from '~/lib/i18n.js';

const posts = await getPublishedPosts();
const categories = buildTaxonomy(posts, 'categories');
---
<BaseLayout pageType="categories" title={t('categories.title')}>
  <section class="taxonomy taxonomy-index categories-page">
    <header class="taxonomy-header">
      <h1 class="archive-title">{t('categories.title')}</h1>
      <span class="archive-count">{categories.length}</span>
    </header>

    <ul class="folder-grid">
      {categories.map((cat) => (
        <li class="folder-card">
          <a href={categoryPath(cat.name)}>
            <span class="folder-icon" aria-hidden="true">
              <svg viewBox="0 0 16 16" width="16" height="16" xmlns="http://www.w3.org/2000/svg" fill="currentColor">
                <path d="M1.75 1A1.75 1.75 0 0 0 0 2.75v10.5C0 14.216.784 15 1.75 15h12.5A1.75 1.75 0 0 0 16 13.25v-8.5A1.75 1.75 0 0 0 14.25 3H7.5a.25.25 0 0 1-.2-.1l-.9-1.2C6.07 1.26 5.55 1 5 1H1.75Z" />
              </svg>
            </span>
            <div class="folder-info">
              <span class="folder-name">{cat.name}</span>
              <span class="folder-count">{cat.length}</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
