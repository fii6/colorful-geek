---
import { themeConfig, siteConfig } from '~/lib/site-config.js';
import { t } from '~/lib/i18n.js';
import { getPublishedPosts, buildTaxonomy, categoryPath, tagPath, tagHue } from '~/lib/posts.js';
import { socialIcon, SOCIAL_ALIASES } from '~/lib/social-icons.js';

export interface Props {
  pageType?: string;
}
const { pageType = 'page' } = Astro.props;

const sb = themeConfig.sidebar || {};
const widgets = sb.widgets || [];
const showOn = sb.show_on || ['home', 'post', 'page', 'archive', 'category', 'tag'];
const visible = sb.enable && showOn.includes(pageType);
if (!visible) return null as any;

const profile = themeConfig.profile || {};
const showCats = widgets.includes('categories') && pageType === 'home';
const showTags = widgets.includes('tags') && pageType === 'home';
const showProfile = widgets.includes('profile') && profile.enable && pageType === 'home';

const posts = await getPublishedPosts();
const categories = showCats ? buildTaxonomy(posts, 'categories') : [];
const tags = showTags ? buildTaxonomy(posts, 'tags') : [];
---
<aside class="sidebar" aria-label="sidebar">
  {widgets.map((widget: string) => {
    if (widget === 'profile' && showProfile) {
      return (
        <section class="widget widget-profile">
          <div class="widget-body">
            {profile.avatar && (
              <img
                class="profile-avatar"
                src={profile.avatar}
                alt="avatar"
                width="64"
                height="64"
                decoding="async"
                fetchpriority="high"
              />
            )}
            <div class="profile-name">{profile.username || siteConfig.author}</div>
            {profile.bio && <div class="profile-bio">{profile.bio}</div>}
            {profile.social && (
              <ul class="profile-social">
                {Object.entries(profile.social).map(([name, url]) => {
                  const icon = socialIcon(name);
                  const label = icon ? icon.label : name;
                  const key = (SOCIAL_ALIASES[name.toLowerCase()] || name.toLowerCase());
                  return (
                    <li>
                      <a
                        href={url as string}
                        target="_blank"
                        rel="noopener"
                        class={`social-link${icon ? '' : ' is-text-only'}`}
                        data-social={key}
                        aria-label={label}
                        title={label}
                      >
                        {icon ? (
                          key === 'email' ? (
                            <svg class="social-svg social-svg-email" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
                              <defs>
                                <linearGradient id="gmail-grad" x1="0" y1="0" x2="1" y2="1">
                                  <stop offset="0%" stop-color="#EA4335" />
                                  <stop offset="35%" stop-color="#FBBC05" />
                                  <stop offset="65%" stop-color="#34A853" />
                                  <stop offset="100%" stop-color="#4285F4" />
                                </linearGradient>
                              </defs>
                              <path fill="url(#gmail-grad)" d={icon.d} />
                            </svg>
                          ) : (
                            <svg class={`social-svg social-svg-${key}`} viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                              <path d={icon.d} />
                            </svg>
                          )
                        ) : (
                          <span class="social-text">{name}</span>
                        )}
                      </a>
                    </li>
                  );
                })}
              </ul>
            )}
          </div>
        </section>
      );
    }

    if (widget === 'categories' && showCats) {
      return (
        <section class="widget widget-categories">
          <div class="widget-label">{t('categories.title')}</div>
          <ul class="widget-body widget-folders">
            {categories.map((cat) => (
              <li>
                <a href={categoryPath(cat.name)}>
                  <span class="folder-mini-icon" aria-hidden="true">
                    <svg class="fm-icon-back" viewBox="0 0 16 16" width="15" height="15" fill="currentColor">
                      <path d="M1.75 2.5A1.75 1.75 0 0 0 0 4.25v8.5C0 13.716.784 14.5 1.75 14.5h12.5A1.75 1.75 0 0 0 16 12.75v-7A1.75 1.75 0 0 0 14.25 4H7.5a.25.25 0 0 1-.2-.1l-.9-1.2C6.07 2.26 5.55 2 5 2H1.75Z"/>
                    </svg>
                    <svg class="fm-icon-front" viewBox="0 0 16 16" width="15" height="15" fill="currentColor">
                      <path d="M.75 4.5h14.5L14 13.5a1 1 0 0 1-.99.875H2.99A1 1 0 0 1 2 13.5L.75 4.5Z"/>
                    </svg>
                  </span>
                  <span class="folder-name">{cat.name}</span>
                  <span class="count">{cat.length}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      );
    }

    if (widget === 'tags' && showTags) {
      return (
        <section class="widget widget-tagcloud">
          <div class="widget-label">{t('tags.title')}</div>
          <ul class="widget-body widget-taglabels">
            {tags.map((tag) => (
              <li>
                <a href={tagPath(tag.name)} style={`--tag-hue: ${tagHue(tag.name)}`}>
                  <svg class="tag-mini-icon" viewBox="0 0 16 16" width="13" height="13" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M1 7.775V2.75A1.75 1.75 0 0 1 2.75 1h5.025a1.75 1.75 0 0 1 1.238.513l6.25 6.25a1.75 1.75 0 0 1 0 2.474l-5.026 5.026a1.75 1.75 0 0 1-2.474 0l-6.25-6.25A1.75 1.75 0 0 1 1 7.775Zm1.5 0c0 .066.026.13.073.177l6.25 6.25a.25.25 0 0 0 .354 0l5.025-5.025a.25.25 0 0 0 0-.354l-6.25-6.25a.25.25 0 0 0-.177-.073H2.75a.25.25 0 0 0-.25.25Z" fill="currentColor" />
                    <circle cx="5" cy="5" r="1" fill="currentColor" />
                  </svg>
                  <span class="tag-name">{tag.name}</span>
                  <span class="count">{tag.length}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      );
    }
    return null;
  })}
</aside>
